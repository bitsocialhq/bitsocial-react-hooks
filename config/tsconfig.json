{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "include": ["../src"],
  "compilerOptions": {
    "module": "ES2020",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "inlineSources": true,
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@bitsocial/bso-resolver": ["../node_modules/@bitsocial/bso-resolver/dist/index.d.ts"]
    },
    "rootDir": "../src",
    "outDir": "../dist",
    "jsx": "react",
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["../**/*.spec.ts", "../**/*.test.ts", "../**/*.donttest.ts"]
}
